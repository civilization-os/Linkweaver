{
  "name": "linkweaver",
  "version": "1.4.7",
  "description": "Linkweaver MCP Server",
  "repository": "civilization-os/Linkweaver",
  "main": "dist/main.js",
  "bin": {
    "linkweaver": "dist/main.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "type": "module",
  "scripts": {
    "build:web": "cd ../web && npm install && npm run build",
    "copy:web": "rimraf public && node -e \"require('fs').cpSync('../web/dist', 'public', {recursive: true})\"",
    "build": "npm run build:web && npm run copy:web && rimraf dist && tsc",
    "start": "electron dist/main.js",
    "dev": "tsc && electron dist/main.js",
    "dist": "npm run build && electron-builder --publish never"
  },
  "build": {
    "appId": "com.linkweaver.app",
    "productName": "Linkweaver",
    "icon": "public/pwa-512x512.png",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "public/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "include": "installer.nsh"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.5.0",
    "@types/dagre": "^0.7.54",
    "cors": "^2.8.5",
    "dagre": "^0.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/proper-lockfile": "^4.1.4",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "license": "MIT"
}
