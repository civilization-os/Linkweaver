{
  "name": "linkweaver",
  "version": "1.4.7",
  "description": "Linkweaver MCP Server",
  "main": "dist/index.js",
  "bin": {
    "linkweaver": "dist/index.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "type": "module",
  "scripts": {
    "build:web": "cd ../web && npm install && npm run build",
    "copy:web": "rimraf public && node -e \"require('fs').cpSync('../web/dist', 'public', {recursive: true})\"",
    "build": "npm run build:web && npm run copy:web && rimraf dist && tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.5.0",
    "@types/dagre": "^0.7.54",
    "cors": "^2.8.5",
    "dagre": "^0.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/proper-lockfile": "^4.1.4",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
